# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ── Environment / Secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
# Keep .env.example files (they're safe — no real secrets)
!**/.env.example

# ── Build output ──────────────────────────────────────────────────────────────
client/dist/
client/build/
dist/
build/
dist-ssr/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Package manager lockfiles (keep package-lock.json, ignore others) ─────────
yarn.lock
pnpm-lock.yaml
.pnp
.pnp.js

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Kiro AI assistant files ───────────────────────────────────────────────────
.kiro/

# ── Test / coverage output ────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
*.tsbuildinfo
.cache/
.parcel-cache/
.turbo/
